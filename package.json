{
  "name": "uni-routefinity",
  "version": "0.0.2",
  "description": "Infinite logical history with bounded page stack for uni-app routing",
  "keywords": [
    "history",
    "routing",
    "uni-app",
    "uni-routefinity"
  ],
  "homepage": "https://github.com/imba97/uni-routefinity#readme",
  "license": "MIT",
  "author": "imba97",
  "repository": {
    "type": "git",
    "url": "git@github.com:imba97/uni-routefinity.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "lint": "vp lint",
    "test": "vp test",
    "type-check": "vp check --type-check",
    "release": "bumpp",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.30",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260410.1",
    "bumpp": "^11.0.1",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.16"
  },
  "packageManager": "pnpm@10.33.0"
}
